                    "additionalProperties": true,
                    "properties": {
                      "origin": {
                        "type": "string",
                        "description": "Origin airport code, e.g. CGK, BKK, SGN"
                      },
                      "destination": {
                        "type": "string",
                        "description": "Destination airport code"
                      }
                    }
                  },
                  "context": {
                    "type": "object",
                    "description": "Authentication context",
                    "properties": {
                      "authServiceToken": {
                        "type": "string",
                        "description": "User JWT token for authentication"
                      }
                    },
                    "required": [
                      "authServiceToken"
                    ]
                  },
                  "clientInterface": {
                    "type": "string",
                    "description": "Client interface type",
                    "default": "DESKTOP"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Response field filter",
                    "default": []
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cached fare data retrieved successfully"
          }
        },
        "tags": [
          "demand"
        ]
      }
    },
