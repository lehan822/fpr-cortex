    "/api/v2/currency-value/convert": {
      "post": {
        "operationId": "convert_currency",
        "summary": "Convert Currency",
        "description": "Convert an amount between currencies using FPR's internal exchange rates. Use when someone asks to 'convert IDR to USD', 'what is 1000 THB in IDR', 'currency conversion', or needs to compare amounts across markets. Keywords: currency conversion, exchange rate, amount conversion.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "fromCurrency",
                  "toCurrency",
                  "amount"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "description": "Request data payload (tool-specific parameters go here)",
                    "additionalProperties": true,
                    "properties": {
                      "fromCurrency": {
                        "type": "string",
                        "description": "Source currency code, e.g. IDR, THB, VND, USD"
                      },
                      "toCurrency": {
                        "type": "string",
                        "description": "Target currency code"
                      },
                      "amount": {
                        "type": "number",
                        "description": "Amount to convert"
                      }
                    }
                  },
                  "context": {
                    "type": "object",
                    "description": "Authentication context",
                    "properties": {
                      "authServiceToken": {
                        "type": "string",
                        "description": "User JWT token for authentication"
                      }
                    },
                    "required": [
                      "authServiceToken"
                    ]
                  },
                  "clientInterface": {
                    "type": "string",
                    "description": "Client interface type",
                    "default": "DESKTOP"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Response field filter",
                    "default": []
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Currency conversion completed successfully"
          }
        },
        "tags": [
          "config"
        ]
      }
    },
