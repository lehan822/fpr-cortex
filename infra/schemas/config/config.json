          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "featureFlag"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "description": "Request data payload (tool-specific parameters go here)",
                    "additionalProperties": true,
                    "properties": {
                      "featureFlag": {
                        "type": "string",
                        "description": "Feature flag name/identifier"
                      }
                    }
                  },
                  "context": {
                    "type": "object",
                    "description": "Authentication context",
                    "properties": {
                      "authServiceToken": {
                        "type": "string",
                        "description": "User JWT token for authentication"
                      }
                    },
                    "required": [
                      "authServiceToken"
                    ]
                  },
                  "clientInterface": {
                    "type": "string",
                    "description": "Client interface type",
                    "default": "DESKTOP"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Response field filter",
                    "default": []
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Flag configuration retrieved successfully"
          }
        },
        "tags": [
          "config"
        ]
      }
    },
    "/api/v2/activity-log/getLogs": {
      "post": {
        "operationId": "get_activity_log",
        "summary": "Get Activity/Audit Log",
        "description": "Retrieve activity and audit logs showing who changed what configuration and when. Essential for tracking config changes and debugging. Use when someone asks 'who changed this', 'audit log', 'activity log', 'recent changes', or 'what was modified'. Keywords: audit log, activity log, configuration changes, change tracking.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "entityType",
                  "entryId"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "description": "Request data payload (tool-specific parameters go here)",
                    "additionalProperties": true,
                    "properties": {
                      "entityType": {
                        "type": "string",
                        "description": "Entity type (CRUD entity name). Common values: flight-PricingAutopilotRules, flight-PricingBaselineRules, flight-CommissionIncentiveRules, flight-PricingBudget, flight-PricePredictionRules, flight-TransactionFee"
                      },
                      "entryId": {
                        "type": "string",
                        "description": "Entry ID to query logs for. For autopilot: {profileGroup}.{profileType}.{productType}.{profileName}.{currency} e.g. AFFILIATE.SPECIFIC.STANDALONE.skyscanner-flight.THB"
                      },
                      "nextToken": {
                        "type": "string",
                        "description": "Pagination token from previous response"
                      }
                    },
                    "required": [
                      "entityType",
                      "entryId"
                    ]
                  },
                  "context": {
                    "type": "object",
                    "description": "Authentication context",
                    "properties": {
                      "authServiceToken": {
                        "type": "string",
                        "description": "User JWT token for authentication"
                      }
                    },
                    "required": [
                      "authServiceToken"
                    ]
                  },
                  "clientInterface": {
                    "type": "string",
                    "description": "Client interface type",
                    "default": "DESKTOP"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Response field filter",
                    "default": []
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Activity logs retrieved successfully"
          }
        },
        "tags": [
          "config"
        ]
      }
    },
