  "paths": {
    "/api/v2/flag/get-applications": {
      "post": {
        "operationId": "get_flag_applications",
        "summary": "List Flag Applications",
        "description": "List all applications that have feature flags configured. Use when someone asks 'which apps have flags', 'flag applications', or needs to know what application names to use. Keywords: flag applications, application list, configured apps.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "description": "Request data payload (tool-specific parameters go here)",
                    "additionalProperties": true
                  },
                  "context": {
                    "type": "object",
                    "description": "Authentication context",
                    "properties": {
                      "authServiceToken": {
                        "type": "string",
                        "description": "User JWT token for authentication"
                      }
                    },
                    "required": [
                      "authServiceToken"
                    ]
                  },
                  "clientInterface": {
                    "type": "string",
                    "description": "Client interface type",
                    "default": "DESKTOP"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Response field filter",
                    "default": []
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of flag applications retrieved successfully"
          }
        },
        "tags": [
          "config"
        ]
      }
    },
    "/api/v2/flag/get-feature-flags-by-application": {
      "post": {
        "operationId": "get_feature_flags",
        "summary": "Get Feature Flags",
        "description": "Retrieve feature flags for a specific application. Shows which features are enabled/disabled and their current state. Use when someone asks about 'feature flags', 'is X feature enabled', 'flag status for fprtckt', or 'what flags are on'. Keywords: feature flags, flag status, feature enablement.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "applicationName"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "description": "Request data payload (tool-specific parameters go here)",
                    "additionalProperties": true,
                    "properties": {
                      "applicationName": {
                        "type": "string",
                        "description": "Application name, e.g. fprtckt, fprcoin, fprlari, fprbud, fprtxf"
                      }
                    }
                  },
                  "context": {
                    "type": "object",
                    "description": "Authentication context",
                    "properties": {
                      "authServiceToken": {
                        "type": "string",
                        "description": "User JWT token for authentication"
                      }
                    },
                    "required": [
                      "authServiceToken"
                    ]
                  },
                  "clientInterface": {
                    "type": "string",
                    "description": "Client interface type",
                    "default": "DESKTOP"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Response field filter",
                    "default": []
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feature flags for application retrieved successfully"
          }
        },
        "tags": [
          "config"
        ]
      }
    },
